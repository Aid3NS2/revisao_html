body {
    background-color: rgb(235, 250, 230);
    margin: 0;
    padding: 0;
    display: flex;
}

aside {
    width: 25%;
    padding-left: 70px;
    margin-left: 0%;
    float: left;
    background-color: rgb(208, 244, 191);

}

#cuteside {
    transform: rotate(90deg) scaleY(-1);
    transform-origin: 0 0;
    position: absolute;
    left: -10px;

}

#Delilah {
    border: 2px solid #91cc98;
    border-radius: 50%;
    padding: 2px;
    margin-left: 20px;
    width: 200px;
}

main {
    float: right;
    margin-left: 25px;
    flex-grow: 1;
}

h1 {
    text-align: center;
    margin-left: 5%;
}

section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    gap: 2rem;

    >div {
        display: flex;
        flex-direction: column;

        >.gal {
            display: grid;
            grid-template-columns: 0.4fr 0.4fr;
            grid-template-rows: 0.4fr 0.4fr;
            gap: 1rem;

            img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }
        }
    }
}
